# Autonoe environment (HashKey Chain)

# AI provider keys (at least one recommended)
GROQ_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Server
PORT=8787

# HashKey Chain RPC
HASHKEY_TESTNET_RPC=https://testnet.hsk.xyz

# Deployer key for contract deploy + seed scripts (never commit a real key)
DEPLOYER_PRIVATE_KEY=

# Liquidity seeding account (often same as deployer for demo)
TREASURY_PRIVATE_KEY=

# Oracle signer for synthetic price attestations
ORACLE_SIGNER_PRIVATE_KEY=

# Optional deploy seed tuning (lower if HSK balance is tight)
# SEED_WHSK=0.03
# SEED_MUSD_BASEUNITS=100000000
# HOUSE_RESERVE_BASEUNITS=500000000
# SYNTH_MARKETS=BTC,ETH,SUI,SOL

# BYBIT_BASE=https://api.bybit.com
# TAVILY_API_KEY=
# AUTONOE_SECRET=
