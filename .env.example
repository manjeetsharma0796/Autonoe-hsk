# ── Autonoe environment ─────────────────────────────────────────────────────
# Copy to ".env" and fill in what you have. Provider keys are OPTIONAL here —
# users can also paste them in the app Settings (stored locally, encrypted).

# ── AI provider keys (free tiers; paste in UI or pre-set here) ───────────────
GROQ_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8787

# ── Mantle Sepolia (chain 5003) ─────────────────────────────────────────────
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz

# Deployer key — used ONLY by contracts/ deploy + seed scripts. NEVER commit a
# real key. Use a throwaway testnet account funded from the faucet.
DEPLOYER_PRIVATE_KEY=

# Account that seeds initial liquidity + funds the SyntheticExchange house
# reserve / owns the mUSD faucet (often = deployer)
TREASURY_PRIVATE_KEY=

# Oracle signer (hybrid synthetic leg, PRD §8). The server signs price
# attestations {symbol, price, timestamp} with this key; its address is set as
# the trusted signer in PriceOracle. Throwaway key — it signs prices, holds no
# funds. Used by GET /api/price/sign (T-210) + PriceOracle (T-110).
ORACLE_SIGNER_PRIVATE_KEY=

# ── Market data ──────────────────────────────────────────────────────────────
# Bybit v5 public market endpoints (kline/tickers) need NO API key. Override the
# base only if you want the testnet endpoint or a proxy.
# BYBIT_BASE=https://api.bybit.com

# Web search (deferred, T-209) — only if you enable the news tool later.
# TAVILY_API_KEY=

# Server-side secret used to encrypt stored provider keys at rest. Set in prod.
# AUTONOE_SECRET=
